# LLM Configuration
# Set MODEL_PROVIDER to "gemini" or "openai"
MODEL_PROVIDER=gemini
MODEL_NAME=gemini-1.5-pro

# API Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# GitHub MCP Configuration
# A GitHub Personal Access Token (PAT) with repo scope is required for PRs and commits.
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_token_here

# Platform Configuration
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=INFO

# Workspace directory for cloning repositories during analysis/testing
WORKSPACE_DIR=./workspace_repos
